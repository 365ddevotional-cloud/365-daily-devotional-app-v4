# Core database connection (Supabase transaction/session string)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@[YOUR-SUPABASE-HOST]:5432/postgres

# Database connection behavior
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=10000
DB_CONNECTION_TIMEOUT_MS=10000
# Set either of these only if your local environment cannot use SSL
# PGSSLMODE=disable
# DISABLE_DB_SSL=true

# Session security
SESSION_SECRET=replace-with-a-long-random-secret

# Frontend and backend connection settings
VITE_API_BASE_URL=https://your-railway-backend.up.railway.app
CORS_ORIGIN=https://your-vercel-frontend.vercel.app

# Timezone used for today's devotional logic
APP_TIMEZONE=America/New_York

# Optional public Supabase values if you later expose direct client reads for non-sensitive content
# VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Direct SendGrid configuration for non-Replit deployments
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=

# Copy any additional production secrets from Replit below before deploying
# STRIPE_SECRET_KEY=
# OPENAI_API_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
